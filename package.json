{
  "name": "vike-vue-pinia-colada",
  "type": "module",
  "version": "0.0.6",
  "packageManager": "bun@1.3.11",
  "description": "Vike extension for Pinia Colada",
  "author": "Kevin Marrec <kevin@marrec.io>",
  "license": "MIT",
  "homepage": "https://github.com/kevinmarrec/vike-vue-pinia-colada#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kevinmarrec/vike-vue-pinia-colada.git"
  },
  "keywords": [
    "vike",
    "vike-extension",
    "pinia",
    "pinia-colada"
  ],
  "exports": {
    "./config": "./dist/+config.mjs",
    "./__internal/integration/onCreateApp": "./dist/integration/+onCreateApp.mjs",
    "./__internal/integration/onAfterRenderHtml": "./dist/integration/+onAfterRenderHtml.mjs",
    "./__internal/integration/onCreatePageContext": "./dist/integration/+onCreatePageContext.mjs"
  },
  "typesVersions": {
    "*": {
      "config": ["./dist/_config.d.mts"],
      "__internal/integration/onCreateApp": ["./dist/integration/_onCreateApp.d.mts"],
      "__internal/integration/onAfterRenderHtml": ["./dist/integration/_onAfterRenderHtml.d.mts"],
      "__internal/integration/onCreatePageContext": ["./dist/integration/_onCreatePageContext.d.mts"]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "check": "bun run lint && bun run knip && bun run typecheck",
    "knip": "knip -n",
    "lint": "eslint . --cache",
    "lint:inspect": "bunx @eslint/config-inspector",
    "typecheck": "tsc --noEmit",
    "release": "bumpp",
    "test": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "peerDependencies": {
    "@pinia/colada": ">=1.0.0",
    "pinia": ">=3.0.0",
    "vike": ">=0.4.255",
    "vike-vue": ">=0.9.0"
  },
  "devDependencies": {
    "@kevinmarrec/eslint-config": "^1.13.1",
    "@kevinmarrec/tsconfig": "^1.13.1",
    "@types/bun": "^1.3.11",
    "@vitest/coverage-v8": "^4.1.2",
    "bumpp": "^11.0.1",
    "eslint": "^9.39.4",
    "knip": "^6.0.6",
    "tsdown": "^0.21.6",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  }
}
